# RustDesk Server Configuration
# Copy to .env and customize as needed

# Domain or IP for relay server (clients will use this to connect)
# For LAN only, use your server IP
# For internet access, use your domain (requires port forwarding or VPN)
RUSTDESK_RELAY_HOST=202.61.192.237

# Key (leave empty to auto-generate, or set a persistent 32-char hex key)
RUSTDESK_KEY=

# Ports (change if you need different external ports)
# 21115: NAT type test
# 21116: ID registration & heartbeat (TCP+UDP)
# 21117: Relay service (TCP)
# 21118/21119: Web client (optional, TCP)
